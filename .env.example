# =============================================================================
# SellerPilot — Complete Environment Variables
# Copy to .env:  cp .env.example .env
# Full setup steps (Gujarati + English): see ENV_SETUP.md
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — App will not work without these
# -----------------------------------------------------------------------------

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Database → Connect → Drivers
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/sellerpilot?retryWrites=true&w=majority"

# Legacy alias (optional — only if you already use DATABASE_URL)
# DATABASE_URL="mongodb+srv://..."

# NextAuth secret — min 32 random characters
# Generate: openssl rand -base64 32   OR   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="paste-32-char-or-longer-secret-here"

# Your app URL (no trailing slash)
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Public URL for emails, crons, webhooks (production = Vercel domain)
APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# AUTH — Google OAuth (optional but recommended)
# Get from: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# -----------------------------------------------------------------------------
# ADMIN — Promoted to ADMIN on db:seed
# -----------------------------------------------------------------------------

ADMIN_EMAIL="you@example.com"

# -----------------------------------------------------------------------------
# FILE STORAGE — Large CSV uploads (Vercel Blob)
# Get from: Vercel Dashboard → Storage → Blob → Create → copy token
# -----------------------------------------------------------------------------

BLOB_READ_WRITE_TOKEN=""

# -----------------------------------------------------------------------------
# PAYMENTS — Razorpay (buy credits)
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# -----------------------------------------------------------------------------

RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# -----------------------------------------------------------------------------
# EMAIL — Resend (report emails, reminders, weekly digest)
# Get from: https://resend.com → API Keys
# -----------------------------------------------------------------------------

RESEND_API_KEY=""
EMAIL_FROM="SellerPilot <onboarding@resend.dev>"

# -----------------------------------------------------------------------------
# AI INSIGHTS — OpenAI (optional)
# Get from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# -----------------------------------------------------------------------------
# WHATSAPP — Twilio (optional; without it, wa.me share link is used)
# Get from: https://console.twilio.com
# -----------------------------------------------------------------------------

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# -----------------------------------------------------------------------------
# CRON SECURITY — Required in production on Vercel
# Generate: openssl rand -hex 32
# Vercel Cron sends: Authorization: Bearer <CRON_SECRET>
# -----------------------------------------------------------------------------

CRON_SECRET=""

# -----------------------------------------------------------------------------
# BACKGROUND JOBS — Upstash QStash (optional, for large CSV queue)
# Get from: https://console.upstash.com → QStash
# -----------------------------------------------------------------------------

QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# -----------------------------------------------------------------------------
# NODE (usually set by Vercel automatically)
# -----------------------------------------------------------------------------

# NODE_ENV=development
